<!DOCTYPE html>
<html lang="it">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0">
    <title>Maglie Senza Ostacoli</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/leaflet/1.9.4/leaflet.min.css" />
    <style>
        body { font-family: sans-serif; margin: 0; padding: 20px; }
        #map { height: 300px; width: 100%; border-radius: 8px; margin-bottom: 15px; }
        .form-group { margin-bottom: 15px; }
        input, textarea, button { width: 100%; padding: 10px; margin-top: 5px; box-sizing: border-box; }
        button { background: #0070f3; color: white; border: none; border-radius: 5px; cursor: pointer; }
    </style>
</head>
<body>
    <h1>Segnala una Barriera a Maglie</h1>
    
    <div id="map"></div>

    <div class="form-group">
        <label>Descrizione del problema:</label>
        <textarea id="desc" placeholder="Es: Marciapiede rotto, auto su scivolo..."></textarea>
    </div>

    <div class="form-group">
        <label>Foto/Video della barriera:</label>
        <input type="file" id="fileInput" accept="image/*,video/*">
    </div>

    <button id="sendBtn">Invia Segnalazione Anonima</button>

    <script type="module">
        import { initializeApp } from "https://www.gstatic.com/firebasejs/10.12.0/firebase-app.js";
        import { getDatabase, ref, push } from "https://www.gstatic.com/firebasejs/10.12.0/firebase-database.js";

        // Tua configurazione rilevata dallo screenshot
        const cfg = {
            apiKey: "AIzaSyCrxqfyDQPZABGt3eWDvhzyRyaJrsipJlA",
            authDomain: "fantasocio.firebaseapp.com",
            databaseURL: "https://fantasocio-default-rtdb.europe-west1.firebasedatabase.app",
            projectId: "fantasocio",
            storageBucket: "fantasocio.appspot.com",
            messagingSenderId: "913473439775",
            appId: "1:913473439775:web:f60b4fae1ed694c997ed2a"
        };

        const app = initializeApp(cfg);
        const db = getDatabase(app);

        // Inizializza Mappa su Maglie
        const map = L.map('map').setView([40.1209, 18.2323], 15);
        L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png').addTo(map);

        let marker;
        map.on('click', (e) => {
            if (marker) map.removeLayer(marker);
            marker = L.marker(e.latlng).addTo(map);
        });

        document.getElementById('sendBtn').onclick = async () => {
            const desc = document.getElementById('desc').value;
            const coords = marker ? marker.getLatLng() : null;

            if (!desc || !coords) return alert("Inserisci descrizione e clicca sulla mappa!");

            try {
                await push(ref(db, 'segnalazioni'), {
                    descrizione: desc,
                    lat: coords.lat,
                    lng: coords.lng,
                    timestamp: Date.now()
                });
                alert("Segnalazione inviata con successo!");
                location.reload();
            } catch (e) {
                alert("Errore nell'invio: " + e.message);
            }
        };
    </script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/leaflet/1.9.4/leaflet.min.js"></script>
</body>
</html>
